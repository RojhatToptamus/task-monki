{
  "name": "task-monki",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Experimental local task board for running Codex in isolated Git worktrees.",
  "author": "Task Monki contributors",
  "homepage": "https://github.com/RojhatToptamus/task-monki#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RojhatToptamus/task-monki.git"
  },
  "bugs": {
    "url": "https://github.com/RojhatToptamus/task-monki/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dev:api": "npm run build:main && node dist-electron/dev/server.js",
    "dev:seed": "npm run build:main && node dist-electron/dev/seed.js --reset",
    "start": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:codex-protocol": "node scripts/generate-codex-protocol.mjs",
    "check:codex-protocol": "node scripts/generate-codex-protocol.mjs --check"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
