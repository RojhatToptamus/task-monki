{
  "name": "task-monki",
  "version": "0.2.0-alpha.1",
  "private": true,
  "license": "MIT",
  "description": "Experimental local task board for running AI coding agents in isolated Git worktrees.",
  "author": "Task Monki contributors",
  "homepage": "https://github.com/RojhatToptamus/task-monki#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RojhatToptamus/task-monki.git"
  },
  "bugs": {
    "url": "https://github.com/RojhatToptamus/task-monki/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1",
    "build:main": "tsc -p tsconfig.main.json && npm run build:preload",
    "build:tools": "tsc -p tsconfig.tools.json",
    "build:preload": "node scripts/build-preload.mjs",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "verify:packaged-preview": "node scripts/verify-packaged-preview-launcher.mjs",
    "verify:packaged-preview-safe-storage": "node scripts/verify-packaged-preview-safe-storage.mjs",
    "dev:api": "npm run build:tools && node dist-tools/dev/server.js",
    "dev:seed": "npm run build:tools && node dist-tools/dev/seed.js --reset",
    "smoke:providers": "npm run build:tools && node dist-tools/dev/providerSmoke.js",
    "start": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "vitest run",
    "test:core": "vitest run src/core",
    "test:renderer": "vitest run src/renderer",
    "test:renderer:dom": "vitest run --config vitest.renderer.config.ts",
    "test:storage": "vitest run src/core/storage",
    "test:agent": "vitest run src/core/agent",
    "test:transport": "vitest run src/dev/devHttpServer.test.ts src/electron src/renderer/api",
    "test:watch": "vitest",
    "check:architecture": "node scripts/check-architecture.mjs",
    "verify": "npm run typecheck && npm run check:architecture && npm test && npm run test:renderer:dom && npm run check:codex-protocol && npm run build",
    "generate:codex-protocol": "node scripts/generate-codex-protocol.mjs",
    "check:codex-protocol": "node scripts/generate-codex-protocol.mjs --check",
    "test:preview-credential-gate": "sh scripts/preview-managed-credential-gate.sh",
    "verify:release-artifacts": "node scripts/verify-release-artifacts.mjs",
    "verify:packaged-runtime": "node scripts/verify-packaged-runtime.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^6.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@electron/asar": "3.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "7zip-bin": "5.2.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "0.21.5",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
